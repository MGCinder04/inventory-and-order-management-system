# Force LF for all text files committed to the repo
* text=auto

# Shell scripts must always be LF — CRLF breaks the shebang inside Linux containers
*.sh text eol=lf

# Python, JS, config — LF in the repo, auto-convert on Windows checkout
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.mako text eol=lf
*.env text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
