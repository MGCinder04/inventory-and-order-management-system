# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=inventory_db

# ── Backend ──────────────────────────────────────────────────────────────────
# Full async DSN — constructed by docker-compose from the Postgres vars above.
# Override this directly when deploying to Render / Railway without Compose.
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@db:5432/inventory_db

# JSON array of origins the backend will accept CORS requests from.
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Number of units at or below which a product is flagged as low-stock.
LOW_STOCK_THRESHOLD=10

# Default look-back window (days) for analytics queries.
ANALYTICS_DEFAULT_DAYS=30

# ── Frontend ─────────────────────────────────────────────────────────────────
# Public URL of the backend API — baked into the Vite bundle at build time.
VITE_API_BASE_URL=http://localhost:8000
